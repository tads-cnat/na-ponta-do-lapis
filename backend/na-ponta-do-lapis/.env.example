# ==========================================
# Configurações de Banco de Dados (Supabase/Postgres)
# ==========================================
# Use a connection string com a porta do pooler (ex: 6543)
DB_URL=jdbc:postgresql://aws-0-sa-east-1.pooler.supabase.com:6543/postgres
DB_USER=postgres.seu_projeto
DB_PASSWORD=insira_sua_senha_do_banco_aqui

# ==========================================
# Segurança e Autenticação
# ==========================================
# Chave secreta usada para assinar os tokens JWT (mínimo 32 caracteres, recomendado 64+)
JWT_SECRET=insira_uma_chave_secreta_longa_e_aleatoria_aqui

# Duração do token de acesso (valores padrão: 1 dia, 1 hora, 5 minutos)
JWT_EXPIRE_DAYS=1
JWT_EXPIRE_HOURS=1
JWT_EXPIRE_MINUTES=5

# Duração do refresh token em dias (padrão: 7)
JWT_EXPIRE_REFRESH_DAYS=7

# URLs permitidas para acessar a API (separadas por vírgula)
# Local: http://localhost:4200 | Prod: https://seu-app.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:4200

# ==========================================
# Integrações Externas (Upload de Imagens)
# ==========================================
CLOUDINARY_CLOUD_NAME=nome_do_seu_cloud_aqui
CLOUDINARY_API_KEY=sua_api_key_aqui
CLOUDINARY_API_SECRET=seu_api_secret_aqui

# ==========================================
# Inteligência Artificial
# ==========================================
GEMINI_API_KEY=sua_chave_do_google_gemini_aqui
# Modelo do Gemini (opcional, padrão: gemini-2.5-flash)
# GEMINI_MODEL_NAME=gemini-2.5-flash